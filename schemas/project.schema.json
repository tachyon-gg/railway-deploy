                "type": "number",
                "exclusiveMinimum": 0
              },
              "vcpus": {
                "description": "vCPU limit.",
                "type": "number",
                "exclusiveMinimum": 0
              }
            },
            "additionalProperties": false
          },
          "railway_config_file": {
            "description": "Path to a railway.json or railway.toml config-as-code file in the repository.",
            "type": "string"
          },
          "static_outbound_ips": {
            "description": "Enable static outbound IPs (egress gateways) for the service.",
            "type": "boolean"
          },
          "private_hostname": {
            "description": "Private network DNS hostname (e.g., 'postgres', 'redis').",
            "type": "string"
          },
          "metal": {
            "description": "Enable Metal build environment (V3).",
            "type": "boolean"
          },
          "template": {
            "description": "Relative path to a service template YAML file.",
            "type": "string"
          },
          "params": {
            "description": "Parameter values to pass to the template, replacing %{param} placeholders.",
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "type": "string"
            }
          },
