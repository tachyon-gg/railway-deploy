{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "project": {
      "type": "string",
      "minLength": 1,
      "description": "Railway project name (must match exactly)."
    },
    "environments": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "List of Railway environment names to manage."
    },
    "shared_variables": {
      "description": "Shared variables. Plain string = same everywhere. Object with value + environments = per-env overrides.",
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string",
            "description": "Simple string value — same for all environments."
          },
          {
            "type": "object",
            "properties": {
              "value": {
                "type": "string",
                "description": "Variable value. Supports ${ENV_VAR} syntax."
              },
              "environments": {
                "description": "Per-environment variable value overrides.",
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "value": {
                      "type": "string",
                      "description": "Variable value. Supports ${ENV_VAR} syntax."
                    }
                  },
                  "required": ["value"],
                  "additionalProperties": false
                }
              }
            },
            "required": ["value"],
            "additionalProperties": false
          }
        ],
        "description": "Shared variable — either a plain string (same everywhere) or object with value + per-env overrides."
      }
    },
    "services": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "source": {
            "description": "Service source — specify either 'image' or 'repo', not both.",
            "type": "object",
            "properties": {
              "image": {
                "description": "Container image (e.g., 'nginx:latest', 'ghcr.io/org/app:v1').",
                "type": "string"
              },
              "repo": {
                "description": "GitHub repository URL.",
                "type": "string"
              },
              "branch": {
                "description": "GitHub branch to deploy from. Changes are auto-deployed from this branch.",
                "type": "string"
              },
              "root_directory": {
                "description": "Root directory for the service (monorepo support).",
                "type": "string"
              },
              "wait_for_ci": {
                "description": "Wait for CI check suites (GitHub Actions) to complete before deploying.",
                "type": "boolean"
              },
              "registry_credentials": {
                "description": "Registry credentials for private container images.",
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string",
                    "description": "Registry username. Supports ${ENV_VAR} syntax."
                  },
                  "password": {
                    "type": "string",
                    "description": "Registry password. Supports ${ENV_VAR} syntax."
                  }
                },
                "required": ["username", "password"],
                "additionalProperties": false
              },
              "auto_updates": {
                "description": "Auto-update configuration for image-based services.",
                "type": "object",
                "properties": {
                  "sunday": {
                    "type": "object",
                    "properties": {
                      "start_hour": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 24,
                        "description": "Start hour (0-24)."
                      },
                      "end_hour": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 24,
                        "description": "End hour (0-24)."
                      }
                    },
                    "required": ["start_hour", "end_hour"],
                    "additionalProperties": false
                  },
                  "monday": {
                    "type": "object",
                    "properties": {
                      "start_hour": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 24,
                        "description": "Start hour (0-24)."
                      },
                      "end_hour": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 24,
                        "description": "End hour (0-24)."
                      }
                    },
                    "required": ["start_hour", "end_hour"],
                    "additionalProperties": false
                  },
                  "tuesday": {
                    "type": "object",
                    "properties": {
                      "start_hour": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 24,
                        "description": "Start hour (0-24)."
                      },
                      "end_hour": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 24,
                        "description": "End hour (0-24)."
                      }
                    },
                    "required": ["start_hour", "end_hour"],
                    "additionalProperties": false
                  },
                  "wednesday": {
                    "type": "object",
                    "properties": {
                      "start_hour": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 24,
                        "description": "Start hour (0-24)."
                      },
                      "end_hour": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 24,
                        "description": "End hour (0-24)."
                      }
                    },
                    "required": ["start_hour", "end_hour"],
                    "additionalProperties": false
                  },
                  "thursday": {
                    "type": "object",
                    "properties": {
                      "start_hour": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 24,
                        "description": "Start hour (0-24)."
                      },
                      "end_hour": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 24,
                        "description": "End hour (0-24)."
                      }
                    },
                    "required": ["start_hour", "end_hour"],
                    "additionalProperties": false
                  },
                  "friday": {
                    "type": "object",
                    "properties": {
                      "start_hour": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 24,
                        "description": "Start hour (0-24)."
                      },
                      "end_hour": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 24,
                        "description": "End hour (0-24)."
                      }
                    },
                    "required": ["start_hour", "end_hour"],
                    "additionalProperties": false
                  },
                  "saturday": {
                    "type": "object",
                    "properties": {
                      "start_hour": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 24,
                        "description": "Start hour (0-24)."
                      },
                      "end_hour": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 24,
                        "description": "End hour (0-24)."
                      }
                    },
                    "required": ["start_hour", "end_hour"],
                    "additionalProperties": false
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          "build": {
            "description": "Build configuration.",
            "type": "object",
            "properties": {
              "builder": {
                "description": "Builder: railpack (default), nixpacks, or dockerfile.",
                "type": "string"
              },
              "command": {
                "description": "Custom build command (Nixpacks/Heroku builds).",
                "type": "string"
              },
              "dockerfile_path": {
                "description": "Path to a custom Dockerfile.",
                "type": "string"
              },
              "watch_patterns": {
                "description": "Gitignore-style patterns to trigger deploys based on changed file paths.",
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          },
          "variables": {
            "description": "Service-level variables. Set to null to delete. Supports ${ENV_VAR} and ${{service.VAR}} syntax.",
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "domains": {
            "description": "Custom domains for this service.",
            "type": "array",
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "object",
                  "properties": {
                    "domain": {
                      "type": "string"
                    },
                    "target_port": {
                      "description": "Target port for the domain.",
                      "type": "integer",
                      "exclusiveMinimum": 0,
                      "maximum": 9007199254740991
                    }
                  },
                  "required": ["domain"],
                  "additionalProperties": false
                }
              ]
            }
          },
          "volume": {
            "description": "Volume reference — name must match a top-level volume key.",
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1,
                "description": "Volume name (must match a top-level volume key)."
              },
              "mount": {
                "type": "string",
                "description": "Mount path inside the container (must be absolute, e.g., '/data')."
              }
            },
            "required": ["name", "mount"],
            "additionalProperties": false
          },
          "regions": {
            "description": "Deployment region(s).",
            "anyOf": [
              {
                "type": "string",
                "minLength": 1,
                "description": "Single region identifier (1 replica)."
              },
              {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "description": "Map of region identifier to replica count (multi-region support)."
              }
            ]
          },
          "restart_policy": {
            "description": "Restart policy: always, never, or on_failure. Can be a string or object with type and max_retries.",
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string"
                  },
                  "max_retries": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  }
                },
                "required": ["type"],
                "additionalProperties": false
              }
            ]
          },
          "healthcheck": {
            "description": "HTTP healthcheck configuration.",
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1,
                "description": "HTTP path for healthcheck (e.g., '/health')."
              },
              "timeout": {
                "description": "Healthcheck timeout in seconds (default: 300).",
                "type": "number",
                "exclusiveMinimum": 0
              }
            },
            "required": ["path"],
            "additionalProperties": false
          },
          "cron_schedule": {
            "description": "Cron schedule (5-field format, e.g., '*/5 * * * *').",
            "type": "string"
          },
          "start_command": {
            "description": "Custom start command for the service.",
            "type": "string"
          },
          "pre_deploy_command": {
            "description": "Command(s) to run before deployment (e.g., DB migrations).",
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            ]
          },
          "serverless": {
            "description": "Enable serverless mode. Containers scale to zero when idle.",
            "type": "boolean"
          },
          "draining_seconds": {
            "description": "Time in seconds between SIGTERM and SIGKILL during deployment teardown.",
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "overlap_seconds": {
            "description": "Time in seconds the old deployment overlaps with the new one during blue-green deploys.",
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "ipv6_egress": {
            "description": "Enable IPv6 outbound traffic for the service.",
            "type": "boolean"
          },
          "railway_domain": {
            "description": "Enable a Railway-provided domain (.up.railway.app). Specify target_port.",
            "type": "object",
