{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Railway Deploy Environment Config",
  "description": "Declarative environment configuration for Railway Deploy. Defines the desired state of a Railway project environment including services, variables, and buckets.",
  "type": "object",
  "required": ["project", "environment", "services"],
  "additionalProperties": false,
  "properties": {
    "project": {
      "type": "string",
      "description": "Railway project name (must match exactly).",
      "minLength": 1
    },
    "environment": {
      "type": "string",
      "description": "Railway environment name (e.g., 'production', 'staging').",
      "minLength": 1
    },
    "shared_variables": {
      "type": "object",
      "description": "Environment-level variables shared across all services. Set a value to null to delete it. Supports ${ENV_VAR} for local env resolution and ${{service.VAR}} for Railway runtime references.",
      "additionalProperties": {
        "oneOf": [{ "type": "string" }, { "type": "null" }]
      }
    },
    "services": {
      "type": "object",
      "description": "Map of service name → service configuration. Each service can reference a template or be defined inline.",
      "additionalProperties": {
        "$ref": "#/$defs/ServiceEntry"
      }
    },
    "buckets": {
      "type": "object",
      "description": "Map of bucket key → bucket configuration. Creates S3-compatible Railway buckets.",
      "additionalProperties": {
        "$ref": "#/$defs/BucketConfig"
      }
    }
  },
  "$defs": {
    "ServiceEntry": {
      "type": "object",
      "description": "Service configuration — either references a template file or defines settings inline.",
      "additionalProperties": false,
      "properties": {
        "template": {
          "type": "string",
          "description": "Relative path to a service template YAML file."
        },
        "params": {
          "type": "object",
          "description": "Parameter values to pass to the template, replacing %{param} placeholders.",
          "additionalProperties": { "type": "string" }
        },
        "variables": {
          "type": "object",
          "description": "Service-level variables. Merged with template variables (overrides take precedence). Set to null to delete. Supports ${ENV_VAR} and ${{service.VAR}} syntax.",
          "additionalProperties": {
            "oneOf": [{ "type": "string" }, { "type": "null" }]
          }
        },
        "source": {
          "$ref": "#/$defs/SourceConfig"
        },
        "domains": {
          "type": "array",
          "description": "Custom domains for this service. Each item can be a string or an object with domain and target_port.",
          "items": {
            "oneOf": [{ "type": "string" }, { "$ref": "#/$defs/DomainWithPort" }]
          }
        },
        "volume": {
          "$ref": "#/$defs/VolumeConfig"
        },
        "region": {
          "$ref": "#/$defs/RegionConfig",
          "description": "Deployment region."
        },
        "restart_policy": {
          "type": "string",
          "description": "Restart policy for the service.",
          "enum": ["ALWAYS", "NEVER", "ON_FAILURE"]
        },
        "healthcheck": {
          "$ref": "#/$defs/HealthcheckConfig"
        },
        "cron_schedule": {
          "type": "string",
          "description": "Cron schedule (5-field format, e.g., '*/5 * * * *'). Minimum interval on Railway is 5 minutes."
        },
        "start_command": {
          "type": "string",
          "description": "Custom start command for the service."
        },
        "build_command": {
          "type": "string",
          "description": "Custom build command (Nixpacks/Heroku builds)."
        },
        "root_directory": {
          "type": "string",
          "description": "Root directory for the service (monorepo support)."
        },
        "dockerfile_path": {
          "type": "string",
          "description": "Path to a custom Dockerfile."
        },
        "pre_deploy_command": {
          "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }],
          "description": "Command(s) to run before deployment (e.g., DB migrations). Accepts a string or array of strings."
        },
        "restart_policy_max_retries": {
          "type": "integer",
          "description": "Max retries for ON_FAILURE restart policy.",
          "minimum": 0
        },
        "sleep_application": {
          "type": "boolean",
          "description": "Enable serverless sleeping. Containers scale to zero when idle and wake on incoming requests."
        },
        "builder": {
          "type": "string",
          "description": "Builder to use for deployments.",
          "enum": ["RAILPACK", "NIXPACKS", "HEROKU", "PAKETO"]
        },
        "watch_patterns": {
          "type": "array",
          "description": "Gitignore-style patterns to trigger deploys based on changed file paths (e.g., '/src/**', 'package.json').",
          "items": { "type": "string" }
        },
        "draining_seconds": {
          "type": "integer",
          "description": "Time in seconds between SIGTERM and SIGKILL during deployment teardown.",
          "minimum": 0
        },
        "overlap_seconds": {
          "type": "integer",
          "description": "Time in seconds the old deployment overlaps with the new one during blue-green deploys.",
          "minimum": 0
        },
        "ipv6_egress": {
          "type": "boolean",
          "description": "Enable IPv6 outbound traffic for the service."
        },
        "branch": {
          "type": "string",
          "description": "GitHub branch to deploy from (e.g., 'main', 'develop'). Changes are auto-deployed from this branch."
        },
        "check_suites": {
          "type": "boolean",
          "description": "Wait for CI check suites (GitHub Actions) to complete before deploying."
        },
        "registry_credentials": {
          "$ref": "#/$defs/RegistryCredentials"
        },
        "railway_domain": {
          "oneOf": [
            { "type": "boolean" },
            {
              "type": "object",
              "required": ["target_port"],
              "additionalProperties": false,
              "properties": {
                "target_port": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Target port for the Railway-provided domain."
                }
              }
            }
          ],
          "description": "Enable a Railway-provided domain (.up.railway.app). Set to true or specify target_port."
        },
        "tcp_proxies": {
          "type": "array",
          "description": "Multiple TCP proxy application ports.",
          "items": { "type": "integer", "minimum": 1 }
        },
        "limits": {
          "$ref": "#/$defs/LimitsConfig"
        },
        "railway_config_file": {
          "type": "string",
          "description": "Path to a railway.json or railway.toml config-as-code file in the repository."
        },
        "static_outbound_ips": {
          "type": "boolean",
          "description": "Enable static outbound IPs (egress gateways) for the service."
        }
      }
    },
    "SourceConfig": {
      "type": "object",
      "description": "Service source — specify either 'image' (container) or 'repo' (GitHub), not both.",
      "additionalProperties": false,
      "properties": {
        "image": {
          "type": "string",
          "description": "Container image (e.g., 'nginx:latest', 'ghcr.io/org/app:v1'). Supports %{param} placeholders."
        },
        "repo": {
          "type": "string",
          "description": "GitHub repository URL."
        }
      }
    },
    "VolumeConfig": {
      "type": "object",
      "description": "Persistent volume configuration.",
      "required": ["mount", "name"],
      "additionalProperties": false,
      "properties": {
        "mount": {
          "type": "string",
          "description": "Mount path inside the container (must be absolute, e.g., '/data').",
          "pattern": "^/"
        },
        "name": {
          "type": "string",
          "description": "Volume name.",
          "minLength": 1
        }
      }
    },
    "HealthcheckConfig": {
      "type": "object",
      "description": "HTTP healthcheck configuration.",
      "required": ["path"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "description": "HTTP path for healthcheck (e.g., '/health').",
          "minLength": 1
        },
        "timeout": {
          "type": "number",
          "description": "Healthcheck timeout in seconds (default: 300).",
          "exclusiveMinimum": 0
        }
      }
    },
    "RegionConfig": {
      "type": "object",
      "description": "Deployment region configuration.",
      "required": ["region"],
      "additionalProperties": false,
      "properties": {
        "region": {
          "type": "string",
          "description": "Railway region identifier.",
          "minLength": 1
        },
        "num_replicas": {
          "type": "integer",
          "description": "Number of replicas in this region (default: 1).",
          "minimum": 1
        }
      }
    },
    "BucketConfig": {
      "type": "object",
      "description": "S3-compatible bucket configuration.",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Bucket name in Railway.",
          "minLength": 1
        }
      }
    },
    "DomainWithPort": {
      "type": "object",
      "description": "Custom domain with optional target port.",
      "required": ["domain"],
      "additionalProperties": false,
      "properties": {
        "domain": {
          "type": "string",
          "description": "Domain name."
        },
        "target_port": {
          "type": "integer",
          "description": "Target port for the domain.",
          "minimum": 1
        }
      }
    },
    "LimitsConfig": {
      "type": "object",
      "description": "Resource limits for the service.",
      "additionalProperties": false,
      "properties": {
        "memory_gb": {
          "type": "number",
          "description": "Memory limit in GB.",
          "exclusiveMinimum": 0
        },
        "vcpus": {
          "type": "number",
          "description": "vCPU limit.",
          "exclusiveMinimum": 0
        }
      }
    },
    "RegistryCredentials": {
      "type": "object",
      "description": "Registry credentials for private container images.",
      "required": ["username", "password"],
      "additionalProperties": false,
      "properties": {
        "username": {
          "type": "string",
          "description": "Registry username. Supports ${ENV_VAR} syntax."
        },
        "password": {
          "type": "string",
          "description": "Registry password. Supports ${ENV_VAR} syntax."
        }
      }
    }
  }
}
