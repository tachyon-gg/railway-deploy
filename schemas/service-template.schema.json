{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "source": {
      "description": "Service source — specify either 'image' or 'repo', not both.",
      "type": "object",
      "properties": {
        "image": {
          "description": "Container image (e.g., 'nginx:latest', 'ghcr.io/org/app:v1').",
          "type": "string"
        },
        "repo": {
          "description": "GitHub repository URL.",
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "variables": {
      "description": "Service-level variables. Set to null to delete. Supports ${ENV_VAR} and ${{service.VAR}} syntax.",
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ]
      }
    },
    "domains": {
      "description": "Custom domains for this service.",
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "object",
            "properties": {
              "domain": {
                "type": "string"
              },
              "target_port": {
                "description": "Target port for the domain.",
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              }
            },
            "required": ["domain"],
            "additionalProperties": false
          }
        ]
      }
    },
    "volume": {
      "description": "Volume reference — name must match a top-level volume key.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Volume name (must match a top-level volume key)."
        },
        "mount": {
          "type": "string",
          "description": "Mount path inside the container (must be absolute, e.g., '/data')."
        }
      },
      "required": ["name", "mount"],
      "additionalProperties": false
    },
    "region": {
      "description": "Deployment region.",
      "type": "object",
      "properties": {
        "region": {
          "type": "string",
          "minLength": 1,
          "description": "Railway region identifier."
        },
        "num_replicas": {
          "description": "Number of replicas in this region (default: 1).",
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": ["region"],
      "additionalProperties": false
    },
    "restart_policy": {
      "description": "Restart policy: ALWAYS, NEVER, or ON_FAILURE. Can be a string or object with type and max_retries.",
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string"
            },
            "max_retries": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            }
          },
          "required": ["type"],
          "additionalProperties": false
        }
      ]
    },
    "healthcheck": {
      "description": "HTTP healthcheck configuration.",
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "HTTP path for healthcheck (e.g., '/health')."
        },
        "timeout": {
          "description": "Healthcheck timeout in seconds (default: 300).",
          "type": "number",
          "exclusiveMinimum": 0
        }
      },
      "required": ["path"],
      "additionalProperties": false
    },
    "cron_schedule": {
      "description": "Cron schedule (5-field format, e.g., '*/5 * * * *').",
      "type": "string"
    },
    "start_command": {
      "description": "Custom start command for the service.",
      "type": "string"
    },
    "build_command": {
      "description": "Custom build command (Nixpacks/Heroku builds).",
      "type": "string"
    },
    "root_directory": {
      "description": "Root directory for the service (monorepo support).",
      "type": "string"
    },
    "dockerfile_path": {
      "description": "Path to a custom Dockerfile.",
      "type": "string"
    },
    "pre_deploy_command": {
      "description": "Command(s) to run before deployment (e.g., DB migrations).",
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ]
    },
    "serverless": {
      "description": "Enable serverless mode. Containers scale to zero when idle.",
      "type": "boolean"
    },
    "builder": {
      "description": "Builder: RAILPACK, NIXPACKS, HEROKU, or PAKETO.",
      "type": "string"
    },
    "watch_patterns": {
      "description": "Gitignore-style patterns to trigger deploys based on changed file paths.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "draining_seconds": {
      "description": "Time in seconds between SIGTERM and SIGKILL during deployment teardown.",
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "overlap_seconds": {
      "description": "Time in seconds the old deployment overlaps with the new one during blue-green deploys.",
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "ipv6_egress": {
      "description": "Enable IPv6 outbound traffic for the service.",
      "type": "boolean"
    },
    "branch": {
      "description": "GitHub branch to deploy from. Changes are auto-deployed from this branch.",
      "type": "string"
    },
    "wait_for_ci": {
      "description": "Wait for CI check suites (GitHub Actions) to complete before deploying.",
      "type": "boolean"
    },
    "registry_credentials": {
      "description": "Registry credentials for private container images.",
      "type": "object",
      "properties": {
        "username": {
          "type": "string",
          "description": "Registry username. Supports ${ENV_VAR} syntax."
        },
        "password": {
          "type": "string",
          "description": "Registry password. Supports ${ENV_VAR} syntax."
        }
      },
      "required": ["username", "password"],
      "additionalProperties": false
    },
    "railway_domain": {
      "description": "Enable a Railway-provided domain (.up.railway.app). Set to true or specify target_port.",
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "object",
          "properties": {
            "target_port": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991,
              "description": "Target port for the Railway-provided domain."
            }
          },
          "required": ["target_port"],
          "additionalProperties": false
        }
      ]
    },
    "tcp_proxies": {
      "description": "Multiple TCP proxy application ports.",
      "type": "array",
      "items": {
        "type": "integer",
        "exclusiveMinimum": 0,
        "maximum": 9007199254740991
      }
    },
    "limits": {
      "description": "Resource limits for the service.",
      "type": "object",
      "properties": {
        "memory_gb": {
          "description": "Memory limit in GB.",
          "type": "number",
          "exclusiveMinimum": 0
        },
        "vcpus": {
          "description": "vCPU limit.",
          "type": "number",
          "exclusiveMinimum": 0
        }
      },
      "additionalProperties": false
    },
    "railway_config_file": {
      "description": "Path to a railway.json or railway.toml config-as-code file in the repository.",
      "type": "string"
    },
    "static_outbound_ips": {
      "description": "Enable static outbound IPs (egress gateways) for the service.",
      "type": "boolean"
    },
    "private_hostname": {
      "description": "Private network DNS hostname (e.g., 'postgres', 'redis').",
      "type": "string"
    },
    "auto_updates": {
      "description": "Auto-update configuration for image-based services.",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "description": "Update type (e.g., 'patch')."
        },
        "schedule": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "day": {
                "type": "integer",
                "minimum": 0,
                "maximum": 6,
                "description": "Day of week (0=Sunday, 6=Saturday)."
              },
              "start_hour": {
                "type": "integer",
                "minimum": 0,
                "maximum": 24,
                "description": "Start hour (0-24)."
              },
              "end_hour": {
                "type": "integer",
                "minimum": 0,
                "maximum": 24,
                "description": "End hour (0-24)."
              }
            },
            "required": ["day", "start_hour", "end_hour"],
            "additionalProperties": false
          },
          "description": "Update schedule entries."
        }
      },
      "required": ["type", "schedule"],
      "additionalProperties": false
    },
    "metal": {
      "description": "Enable Metal build environment (V3).",
      "type": "boolean"
    },
    "params": {
      "description": "Parameter definitions. Each param can be required or have a default value.",
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "required": {
            "description": "Whether this parameter must be provided by the environment config.",
            "type": "boolean"
          },
          "default": {
            "description": "Default value if not provided by the environment config.",
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "description": "Reusable service template with parameterized configuration.",
  "title": "Railway Deploy Service Template"
}
