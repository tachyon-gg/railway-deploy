{
  "name": "railway-deploy",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "codegen": "graphql-codegen --config codegen.ts",
    "test": "bun test --bail --test-name-pattern '^(?!Railway Integration)' test/",
    "test:coverage": "bun test --bail --coverage --coverage-reporter=text --coverage-reporter=lcov --coverage-dir=coverage test/cli.test.ts test/diff.test.ts test/loader.test.ts test/params.test.ts test/variables.test.ts",
    "test:integration": "bun test --bail --timeout 30000 --env-file .env.test test/integration/",
    "test:all": "bun test --bail --timeout 30000 --env-file .env.test test/",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@graphql-typed-document-node/core": "^3.2.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "graphql": "^16.10.0",
    "graphql-request": "^7.1.2",
    "yaml": "^2.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@graphql-codegen/cli": "^5.0.3",
    "@graphql-codegen/typed-document-node": "^6.1.7",
    "@graphql-codegen/typescript": "^4.1.2",
    "@graphql-codegen/typescript-operations": "^4.4.0",
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
